<wxs module="utils">
module.exports = {
  getPriorityVariant: function(priority) {
    var map = { high: 'danger', medium: 'warning', low: 'success' };
    return map[priority] || 'info';
  },
  getPriorityLabel: function(priority, lang) {
    if (lang === 'zh') {
      var zh = { high: '高', medium: '中', low: '低' };
      return zh[priority] || '';
    }
    var en = { high: 'High', medium: 'Medium', low: 'Low' };
    return en[priority] || '';
  },
  getCategoryName: function(categoryId, categories) {
    // If already a full object, use its name directly
    if (categoryId && typeof categoryId === 'object' && categoryId.name) {
      return categoryId.name;
    }
    var id = categoryId;
    for (var i = 0; i < categories.length; i++) {
      if (categories[i].id === id) return categories[i].name;
    }
    return '';
  },
  getCategoryColor: function(categoryId, categories) {
    // If already a full object, use its color directly
    if (categoryId && typeof categoryId === 'object' && categoryId.color) {
      return categoryId.color;
    }
    var id = categoryId;
    for (var i = 0; i < categories.length; i++) {
      if (categories[i].id === id) return categories[i].color;
    }
    return '';
  },
  hasCategoryName: function(categoryId, categories) {
    if (categoryId && typeof categoryId === 'object' && categoryId.name) {
      return true;
    }
    if (!categoryId) return false;
    for (var i = 0; i < categories.length; i++) {
      if (categories[i].id === categoryId) return true;
    }
    return false;
  },
  actionText: function(key, pinned, lang) {
    if (lang === 'zh') {
      if (key === 'pin') return pinned ? '取消置顶' : '置顶';
      if (key === 'edit') return '编辑';
      if (key === 'delete') return '删除';
    }
    if (key === 'pin') return pinned ? 'Unpin' : 'Pin';
    if (key === 'edit') return 'Edit';
    if (key === 'delete') return 'Delete';
    return '';
  }
};
</wxs>

<view class="todo-item {{todo.done ? 'todo-item--done' : ''}}">
  <view class="todo-left" bind:tap="onToggle">
    <view class="todo-checkbox {{todo.done ? 'todo-checkbox--checked' : ''}}">
      <text wx:if="{{todo.done}}" class="todo-check-icon">✓</text>
    </view>
  </view>

  <view class="todo-content">
    <text class="todo-text {{todo.done ? 'todo-text--done' : ''}}">{{todo.content}}</text>
    <view class="todo-meta" wx:if="{{todo.priority || todo.category}}">
      <view wx:if="{{todo.priority}}" class="priority-badge-wrap">
        <badge text="{{utils.getPriorityLabel(todo.priority, _lang)}}" variant="{{utils.getPriorityVariant(todo.priority)}}"></badge>
      </view>
      <badge wx:if="{{utils.hasCategoryName(todo.category, categories)}}" text="{{utils.getCategoryName(todo.category, categories)}}" customColor="{{utils.getCategoryColor(todo.category, categories)}}"></badge>
    </view>
  </view>

  <view class="todo-right">
    <view class="todo-actions">
      <view wx:if="{{todo.pinned}}" class="todo-pin-btn" bind:tap="onPin">
        <text class="pin-icon pin-icon--active">📌</text>
      </view>
      <view class="todo-more-btn" bind:tap="onToggleActions">
        <text class="more-icon">···</text>
      </view>

      <view class="todo-action-menu {{showActions ? 'todo-action-menu--show' : ''}}" wx:if="{{showActions}}">
        <view class="todo-action-item" bind:tap="onPin">
          <text>{{utils.actionText('pin', todo.pinned, _lang)}}</text>
        </view>
        <view class="todo-action-item" bind:tap="onEdit">
          <text>{{utils.actionText('edit', false, _lang)}}</text>
        </view>
        <view class="todo-action-item todo-action-item--danger" bind:tap="onDelete">
          <text>{{utils.actionText('delete', false, _lang)}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
