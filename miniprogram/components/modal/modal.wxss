/* Mask */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.modal-mask--show {
  /* show state */
}

/* Bottom Sheet */
.modal-sheet {
  width: 100%;
  background: #1a1a1a;
  border-radius: 32rpx 32rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 80vh;
}

/* Header */
.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.modal-close {
  font-size: 48rpx;
  color: #737373;
  line-height: 1;
  padding: 0 8rpx;
}

/* Body */
.modal-body {
  padding: 16rpx 32rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* Footer */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx 32rpx;
}

.modal-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn::after {
  border: none;
}

.modal-btn--cancel {
  background: #2a2a2a;
  color: #a0a0a0;
}

.modal-btn--confirm {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
}

.modal-btn:active {
  opacity: 0.8;
}
