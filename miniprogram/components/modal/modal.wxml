<view class="modal-mask {{show ? 'modal-mask--show' : ''}}" wx:if="{{show}}" catchtouchmove="preventTouchMove" bind:tap="onMaskClick">
  <view class="modal-sheet" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{title}}</text>
      <text class="modal-close" bind:tap="onClose">×</text>
    </view>

    <view class="modal-body">
      <slot></slot>
    </view>

    <view class="modal-footer" wx:if="{{!hideFooter}}">
      <view class="modal-btn modal-btn--cancel" bind:tap="onClose">
        <text>取消</text>
      </view>
      <view class="modal-btn modal-btn--confirm" bind:tap="onConfirm">
        <text>确定</text>
      </view>
    </view>
  </view>
</view>
