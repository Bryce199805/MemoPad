.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
}

.empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.empty-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.empty-desc {
  display: none;
}
