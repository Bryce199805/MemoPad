.empty-state {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 24rpx;
}

.empty-icon {
  font-size: 40rpx;
  flex-shrink: 0;
}

.empty-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  white-space: nowrap;
}

.empty-desc {
  display: none;
}
