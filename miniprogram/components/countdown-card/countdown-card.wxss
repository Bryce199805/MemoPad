.countdown-card {
  position: relative;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  padding: 24rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.countdown-strip {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
}

.countdown-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.countdown-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.countdown-body {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.countdown-days {
  font-size: 48rpx;
  font-weight: 700;
  color: #e5e5e5;
  line-height: 1;
}

.countdown-days-label {
  font-size: 24rpx;
  color: #737373;
  margin-left: 6rpx;
}

.countdown-date {
  font-size: 22rpx;
  color: #525252;
  display: block;
  margin-bottom: 16rpx;
}

.countdown-footer {
  display: flex;
  gap: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  padding-top: 16rpx;
}

.countdown-action {
  font-size: 22rpx;
  color: #737373;
  padding: 6rpx 0;
}

.countdown-action--danger {
  color: #ef4444;
}

.countdown-action:active {
  opacity: 0.6;
}
