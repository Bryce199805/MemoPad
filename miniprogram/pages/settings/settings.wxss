/* Settings Page */
.settings-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

/* Loading Skeleton */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 200rpx;
  background: var(--bg-tertiary);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-section {
  height: 240rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-section:nth-child(2) { animation-delay: 0.1s; }
.skeleton-section:nth-child(3) { animation-delay: 0.2s; }

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* Header */
.settings-header {
  margin-bottom: 32rpx;
}

.settings-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

/* Section Card */
.section-card {
  margin-bottom: 24rpx;
}

.section-card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 24rpx;
}

/* Profile */
.profile-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.profile-email {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-role {
  font-size: 22rpx;
  color: var(--accent-primary);
  display: block;
  margin-top: 4rpx;
}

/* Category Add Form */
.cat-add-form {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1px solid var(--border-subtle);
}

.cat-name-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 24rpx 20rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.cat-name-input:focus {
  border-color: var(--accent-primary);
}

.cat-color-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 20rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.cat-color-dot {
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
}

.cat-color-dot--sm {
  width: 20rpx;
  height: 20rpx;
}

.cat-add-btn {
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: var(--radius-md);
  flex-shrink: 0;
}

.cat-add-btn:active {
  opacity: 0.85;
}

.cat-add-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.chip-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* Category List */
.cat-list {
  display: flex;
  flex-direction: column;
}

.cat-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1px solid var(--border-subtle);
}

.cat-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.cat-item-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.cat-item-name {
  font-size: 28rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cat-item-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.cat-item-count {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 500;
  min-width: 32rpx;
  text-align: center;
}

.cat-delete-btn {
  padding: 8rpx;
}

.cat-delete-icon {
  font-size: 24rpx;
  color: var(--text-muted);
}

.cat-delete-btn:active .cat-delete-icon {
  color: var(--danger);
}

/* Category Edit */
.cat-edit-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 24rpx 20rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.cat-edit-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.cat-save-btn {
  padding: 16rpx 24rpx;
  background: var(--success);
  border-radius: var(--radius-md);
}

.cat-save-btn:active {
  opacity: 0.85;
}

.cat-save-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

.cat-cancel-btn {
  padding: 16rpx 24rpx;
  background: var(--bg-tertiary);
  border-radius: var(--radius-md);
}

.cat-cancel-btn:active {
  opacity: 0.7;
}

.cat-cancel-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.cat-empty {
  padding: 16rpx 0;
}

/* Server Info */
.server-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.server-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.server-value {
  font-size: 26rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

/* Admin Link */
.admin-link {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(99, 102, 241, 0.08);
  border-radius: var(--radius-md);
}

.admin-link:active {
  opacity: 0.7;
}

.admin-link-text {
  font-size: 28rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

.arrow {
  font-size: 28rpx;
  color: var(--accent-primary);
}

.link-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.unread-badge {
  background: #ef4444;
  border-radius: 999rpx;
  padding: 2rpx 12rpx;
  min-width: 32rpx;
  text-align: center;
}

.unread-badge-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #fff;
  line-height: 28rpx;
}

/* Danger Zone */
.danger-zone {
  border: 1px solid rgba(239, 68, 68, 0.2);
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
  padding: 24rpx;
  border-radius: 20rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
}

.logout-btn:active {
  opacity: 0.7;
}

.logout-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ef4444;
}

/* Delete Account */
.section-card-title--danger {
  color: #ef4444;
}

.danger-desc {
  font-size: 24rpx;
  color: #737373;
  margin-bottom: 16rpx;
  display: block;
}

.delete-account-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  background: rgba(239, 68, 68, 0.15);
  border-radius: 12rpx;
}

.delete-account-btn:active {
  opacity: 0.7;
}

.delete-account-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ef4444;
}

/* Language Options */
.section-desc {
  font-size: 24rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 16rpx;
}

.lang-options {
  display: flex;
  gap: 16rpx;
}

.lang-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-secondary);
}

.lang-btn:active {
  opacity: 0.8;
}

.lang-btn--active {
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-color: transparent;
  color: #ffffff;
}

.lang-btn--active text {
  color: #ffffff;
}

/* About Section */
.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1px solid var(--border-subtle);
}

.about-row:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.about-label {
  font-size: 26rpx;
  color: var(--text-muted);
}

.about-value {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.about-link {
  font-size: 24rpx;
  color: var(--accent-primary);
}

.about-row--link:active {
  opacity: 0.7;
}
