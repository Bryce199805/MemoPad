<view class="settings-page">
  <!-- Loading Skeleton -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-header"></view>
    <view class="skeleton-section"></view>
    <view class="skeleton-section"></view>
    <view class="skeleton-section"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="settings-header">
      <text class="settings-title">{{i.title}}</text>
    </view>

    <!-- Profile Section -->
    <view class="section-card glass-card">
      <text class="section-card-title">{{i.profile}}</text>
      <view class="profile-row">
        <view class="avatar-circle">
          <text class="avatar-letter">{{user.username ? user.username[0].toUpperCase() : '?'}}</text>
        </view>
        <view class="profile-info">
          <text class="profile-name">{{user.username || 'Unknown'}}</text>
          <text class="profile-email">{{user.email || i.noEmail}}</text>
          <text class="profile-role" wx:if="{{user.role}}">{{user.role}}</text>
        </view>
      </view>
    </view>

    <!-- Categories Section -->
    <view class="section-card glass-card">
      <text class="section-card-title">{{i.categories}}</text>

      <!-- Add Form -->
      <view class="cat-add-form">
        <input class="cat-name-input" placeholder="{{i.newCategoryPlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{newCatName}}" bindinput="onCatNameInput" maxlength="30" />
        <picker mode="selector" range="{{colorLabels}}" value="{{newCatColorIdx}}" bindchange="onCatColorChange">
          <view class="cat-color-picker">
            <view class="cat-color-dot" style="background: {{newCatColor}}"></view>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>
        <view class="cat-add-btn" bind:tap="onAddCategory">
          <text class="cat-add-text">{{i.add}}</text>
        </view>
      </view>

      <!-- Category List -->
      <view class="cat-list" wx:if="{{categories.length > 0}}">
        <view class="cat-item" wx:for="{{categories}}" wx:key="id">
          <!-- Edit Mode -->
          <block wx:if="{{editingCatId === item.id}}">
            <input class="cat-name-input cat-edit-input" placeholder="{{i.newCategoryPlaceholder}}" placeholder-style="color: var(--text-muted)"
              value="{{editingCatName}}" bindinput="onEditingCatNameInput" maxlength="30" />
            <picker mode="selector" range="{{colorLabels}}" value="{{editingCatColorIdx}}" bindchange="onEditingCatColorChange">
              <view class="cat-color-picker">
                <view class="cat-color-dot" style="background: {{editingCatColor}}"></view>
                <text class="chip-arrow">▾</text>
              </view>
            </picker>
            <view class="cat-edit-btns">
              <view class="cat-save-btn" bind:tap="onSaveEditCategory">
                <text class="cat-save-text">{{i.save}}</text>
              </view>
              <view class="cat-cancel-btn" bind:tap="onCancelEditCategory">
                <text class="cat-cancel-text">{{i.cancel}}</text>
              </view>
            </view>
          </block>
          <!-- View Mode -->
          <block wx:else>
            <view class="cat-item-left" bind:tap="onEditCategory" data-id="{{item.id}}">
              <view class="cat-color-dot cat-color-dot--sm" style="background: {{item.color || '#6366f1'}}"></view>
              <text class="cat-item-name">{{item.name}}</text>
            </view>
            <view class="cat-item-right">
              <text class="cat-item-count">{{catUsageCounts[item.id] || 0}}</text>
              <view class="cat-delete-btn" bind:tap="onDeleteCategory" data-id="{{item.id}}" data-name="{{item.name}}">
                <text class="cat-delete-icon">✕</text>
              </view>
            </view>
          </block>
        </view>
      </view>

      <view wx:if="{{categories.length === 0}}" class="cat-empty">
        <empty-state
          icon="🏷"
          title="{{i.noCategories}}"
          description="">
        </empty-state>
      </view>
    </view>

    <!-- Feedback Section -->
    <view class="section-card glass-card" wx:if="{{user.role !== 'admin'}}">
      <text class="section-card-title">{{i.support}}</text>
      <view class="admin-link" bind:tap="onGoTickets">
        <text class="admin-link-text">{{i.feedbackIssues}}</text>
        <view class="link-right">
          <view class="unread-badge" wx:if="{{unreadCount > 0}}">
            <text class="unread-badge-text">{{unreadCount > 9 ? '9+' : unreadCount}}</text>
          </view>
          <text class="arrow">→</text>
        </view>
      </view>
    </view>

    <!-- Admin Section -->
    <view class="section-card glass-card" wx:if="{{user.role === 'admin'}}">
      <text class="section-card-title">{{i.admin}}</text>
      <view class="admin-link" bind:tap="onGoAdmin">
        <text class="admin-link-text">{{i.adminPanel}}</text>
        <text class="arrow">→</text>
      </view>
    </view>

    <!-- Language Section -->
    <view class="section-card glass-card">
      <text class="section-card-title">{{i.language}}</text>
      <text class="section-desc">{{i.languageDesc}}</text>
      <view class="lang-options">
        <view class="lang-btn {{currentLang === 'en' ? 'lang-btn--active' : ''}}" bind:tap="setLang" data-lang="en">
          <text>🌐 English</text>
        </view>
        <view class="lang-btn {{currentLang === 'zh' ? 'lang-btn--active' : ''}}" bind:tap="setLang" data-lang="zh">
          <text>🌏 中文</text>
        </view>
      </view>
    </view>

    <!-- Danger Zone -->
    <view class="section-card danger-zone">
      <view class="logout-btn" bind:tap="onLogout">
        <text class="logout-text">{{i.logout}}</text>
      </view>
    </view>

    <!-- Delete Account (non-admin only) -->
    <view class="section-card danger-zone" wx:if="{{user.role !== 'admin'}}">
      <text class="section-card-title section-card-title--danger">{{i.deleteAccount}}</text>
      <text class="danger-desc">{{i.deleteAccountDesc}}</text>
      <view class="delete-account-btn" bind:tap="onDeleteAccount">
        <text class="delete-account-text">{{i.deleteAccount}}</text>
      </view>
    </view>

    <!-- About Section -->
    <view class="section-card glass-card">
      <text class="section-card-title">{{i.about}}</text>
      <view class="about-row">
        <text class="about-label">{{i.version}}</text>
        <text class="about-value">{{appVersion}}</text>
      </view>
      <view class="about-row about-row--link" bind:tap="onCopyGithub">
        <text class="about-label">{{i.sourceCode}}</text>
        <text class="about-link">github.com/Bryce199805/MemoPad ↗</text>
      </view>
    </view>

    <view class="safe-bottom"></view>
  </block>
</view>
