/* Admin Page - Orange Theme with Bottom Tabs */
.admin-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1207 0%, #0a0a0a 100%);
  display: flex;
  flex-direction: column;
}

/* Loading */
.loading-skeleton {
  padding: 32rpx;
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 250rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

/* Header */
.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
  flex-shrink: 0;
}

.admin-header-left {
  display: flex;
  flex-direction: column;
}

.admin-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f59e0b;
}

.admin-subtitle {
  font-size: 24rpx;
  color: #737373;
  margin-top: 4rpx;
}

.logout-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 12rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
}

/* Content Area */
.admin-content {
  flex: 1;
  overflow-y: auto;
  padding-bottom: 140rpx;
}

/* Tab Content */
.tab-content {
  padding: 0 32rpx 32rpx;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.2s ease;
}

.stat-card:active {
  opacity: 0.8;
}

.stat-card--active {
  border-color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}

.stat-value--success { color: #22c55e; }
.stat-value--warning { color: #eab308; }

.stat-label {
  font-size: 22rpx;
  color: #737373;
  margin-top: 8rpx;
  display: block;
}

/* Expanded Preview */
.expanded-section {
  background: rgba(255, 255, 255, 0.02);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.expanded-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.expanded-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #f59e0b;
}

.expanded-collapse {
  font-size: 22rpx;
  color: #737373;
  padding: 8rpx 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 8rpx;
}

.expanded-list {
  padding: 16rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

/* Section */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  margin-bottom: 16rpx;
  display: block;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ticket-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.ticket-card:active {
  opacity: 0.8;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.ticket-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e5e5e5;
  flex: 1;
  margin-right: 12rpx;
}

.ticket-body {
  margin-bottom: 8rpx;
}

.ticket-desc {
  font-size: 24rpx;
  color: #737373;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
}

.ticket-meta {
  display: flex;
  gap: 16rpx;
}

.ticket-user {
  font-size: 22rpx;
  color: #f59e0b;
}

.ticket-date {
  font-size: 22rpx;
  color: #525252;
}

/* Status Badge */
.ticket-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  text-transform: capitalize;
}

.ticket-status--open { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.ticket-status--in_progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.ticket-status--resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.ticket-status--closed { background: rgba(115, 115, 115, 0.15); color: #737373; }

/* User List - Compact Rows */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  overflow: hidden;
}

.user-row-compact {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 20rpx;
  background: rgba(255, 255, 255, 0.01);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.user-row-compact:last-child {
  border-bottom: none;
}

.user-avatar-sm {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter-sm {
  font-size: 20rpx;
  font-weight: 700;
  color: #1a1207;
}

.user-info-compact {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.user-name-compact {
  font-size: 26rpx;
  font-weight: 500;
  color: #e5e5e5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-stats-compact {
  font-size: 20rpx;
  color: #525252;
  flex-shrink: 0;
}

.user-actions-compact {
  display: flex;
  gap: 8rpx;
  flex-shrink: 0;
}

.action-btn--compact {
  padding: 6rpx 14rpx !important;
  font-size: 20rpx !important;
}

.badge {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.badge--admin {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.badge--disabled {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* User Actions */
.self-label {
  font-size: 22rpx;
  color: #525252;
  font-style: italic;
}

.action-btn {
  font-size: 22rpx;
  color: #737373;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.04);
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn--primary {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.action-btn--success {
  color: #22c55e;
  background: rgba(34, 197, 94, 0.1);
}

.action-btn--danger {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

.action-btn--accent {
  color: #6366f1;
  background: rgba(99, 102, 241, 0.12);
}

/* Detail Modal */
.ticket-detail {
  padding: 0 8rpx;
}

.detail-row {
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #525252;
  display: block;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #e5e5e5;
}

.detail-value--block {
  display: block;
  line-height: 1.5;
}

.reply-input {
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #e5e5e5;
  font-size: 26rpx;
  box-sizing: border-box;
}

/* Reply Thread */
.reply-thread {
  padding-top: 16rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.no-replies-hint {
  font-size: 24rpx;
  color: #525252;
  padding: 8rpx 0;
}

.reply-item {
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
}

.reply-item--admin {
  background: rgba(20, 184, 166, 0.06);
  border-left: 4rpx solid rgba(20, 184, 166, 0.4);
}

.reply-item--user {
  background: rgba(99, 102, 241, 0.06);
  border-left: 4rpx solid rgba(99, 102, 241, 0.4);
}

.reply-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.reply-item-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #14b8a6;
  text-transform: uppercase;
}

.reply-item-label--user {
  font-size: 20rpx;
  font-weight: 600;
  color: #6366f1;
  text-transform: uppercase;
}

.reply-item-time {
  font-size: 20rpx;
  color: #525252;
}

.reply-item-content {
  font-size: 26rpx;
  color: #a3a3a3;
  white-space: pre-wrap;
  line-height: 1.5;
  display: block;
  margin-bottom: 8rpx;
}

.reply-send-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.action-btn--sm {
  padding: 8rpx 20rpx !important;
  font-size: 22rpx !important;
  align-self: flex-end;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.detail-close {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.detail-close .action-btn {
  padding: 16rpx 48rpx;
}

/* Empty */
.empty-state {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #525252;
}

/* Filter Row */
.filter-row {
  margin-bottom: 16rpx;
}

.filter-picker {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #a3a3a3;
}

.chip-arrow {
  font-size: 20rpx;
  color: #525252;
}

/* Config Tab */
.config-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.config-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.config-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #e5e5e5;
}

.config-desc {
  font-size: 22rpx;
  color: #737373;
}

/* Bottom Tabs */
.bottom-tabs {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: #1a1207;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.bottom-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.bottom-tab:active {
  opacity: 0.8;
}

.bottom-tab--active {
  color: #f59e0b;
}

.bottom-tab-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.bottom-tab-text {
  font-size: 20rpx;
  color: #737373;
}

.bottom-tab--active .bottom-tab-text {
  color: #f59e0b;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
