/* Admin Page - Orange Theme with Tabs */
.admin-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1207 0%, #0a0a0a 100%);
}

/* Loading */
.loading-skeleton {
  padding: 32rpx;
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 250rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.skeleton-tabs {
  height: 100rpx;
  background: rgba(255, 255, 255, 0.05);
  margin-bottom: 24rpx;
}

.skeleton-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

/* Header */
.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 16rpx;
}

.admin-header-left {
  display: flex;
  flex-direction: column;
}

.admin-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f59e0b;
}

.admin-subtitle {
  font-size: 24rpx;
  color: #737373;
  margin-top: 4rpx;
}

.logout-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 12rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
}

/* Tabs */
.admin-tabs {
  display: flex;
  padding: 0 16rpx;
  margin-bottom: 16rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.admin-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  position: relative;
}

.admin-tab--active {
  color: #f59e0b;
}

.admin-tab--active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 4rpx;
  background: #f59e0b;
  border-radius: 2rpx;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 22rpx;
  color: #737373;
}

.admin-tab--active .tab-text {
  color: #f59e0b;
}

/* Tab Content */
.tab-content {
  padding: 0 32rpx 32rpx;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-card:active {
  opacity: 0.8;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}

.stat-value--success { color: #22c55e; }
.stat-value--warning { color: #eab308; }

.stat-label {
  font-size: 22rpx;
  color: #737373;
  margin-top: 8rpx;
  display: block;
}

/* Section */
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  margin-bottom: 16rpx;
  display: block;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ticket-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.ticket-card:active {
  opacity: 0.8;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.ticket-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e5e5e5;
  flex: 1;
  margin-right: 12rpx;
}

.ticket-body {
  margin-bottom: 8rpx;
}

.ticket-desc {
  font-size: 24rpx;
  color: #737373;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
}

.ticket-meta {
  display: flex;
  gap: 16rpx;
}

.ticket-user {
  font-size: 22rpx;
  color: #f59e0b;
}

.ticket-date {
  font-size: 22rpx;
  color: #525252;
}

/* Status Badge */
.ticket-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  text-transform: capitalize;
}

.ticket-status--open { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.ticket-status--in_progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.ticket-status--resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.ticket-status--closed { background: rgba(115, 115, 115, 0.15); color: #737373; }

/* User List */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1207;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.badge {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.badge--admin {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.badge--disabled {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.user-email {
  font-size: 22rpx;
  color: #525252;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-stats {
  font-size: 20rpx;
  color: #404040;
  margin-top: 2rpx;
  display: block;
}

/* User Actions */
.user-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
}

.user-actions--self {
  justify-content: flex-end;
}

.self-label {
  font-size: 22rpx;
  color: #525252;
  font-style: italic;
}

.action-btn {
  font-size: 22rpx;
  color: #737373;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.04);
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn--primary {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.action-btn--success {
  color: #22c55e;
  background: rgba(34, 197, 94, 0.1);
}

.action-btn--danger {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

/* Detail Modal */
.ticket-detail {
  padding: 0 8rpx;
}

.detail-row {
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #525252;
  display: block;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #e5e5e5;
}

.detail-value--block {
  display: block;
  line-height: 1.5;
}

.reply-input {
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #e5e5e5;
  font-size: 26rpx;
  box-sizing: border-box;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.detail-close {
  display: flex;
  justify-content: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
}

.detail-close .action-btn {
  padding: 16rpx 48rpx;
}

/* Empty */
.empty-state {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #525252;
}

/* Filter Row */
.filter-row {
  margin-bottom: 16rpx;
}

.filter-picker {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #a3a3a3;
}

.chip-arrow {
  font-size: 20rpx;
  color: #525252;
}

/* Config Tab */
.config-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.config-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.config-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.config-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #e5e5e5;
}

.config-desc {
  font-size: 22rpx;
  color: #737373;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
