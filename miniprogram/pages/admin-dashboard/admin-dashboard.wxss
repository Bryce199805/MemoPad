/* Admin Page - Orange Theme */
.admin-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
  background: linear-gradient(180deg, #1a1207 0%, #0a0a0a 100%);
}

/* Loading */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 250rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.skeleton-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.skeleton-card {
  height: 140rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
}

/* Header */
.admin-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.admin-header-left {
  display: flex;
  flex-direction: column;
}

.admin-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f59e0b;
}

.admin-subtitle {
  font-size: 24rpx;
  color: #a3a3a3;
  margin-top: 4rpx;
}

.logout-btn {
  font-size: 24rpx;
  color: #ef4444;
  padding: 12rpx 24rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: 12rpx;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.stat-card:active {
  opacity: 0.8;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #f59e0b;
  display: block;
}

.stat-value--success { color: #22c55e; }
.stat-value--warning { color: #eab308; }

.stat-label {
  font-size: 22rpx;
  color: #737373;
  margin-top: 8rpx;
  display: block;
}

/* Section */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  margin-bottom: 16rpx;
  display: block;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.view-all {
  font-size: 24rpx;
  color: #f59e0b;
}

/* Action Grid */
.action-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.action-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  text-align: center;
}

.action-card:active {
  opacity: 0.8;
  border-color: rgba(245, 158, 11, 0.3);
}

.action-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  display: block;
}

.action-count {
  font-size: 22rpx;
  color: #737373;
  margin-top: 8rpx;
  display: block;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ticket-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.ticket-card:active {
  opacity: 0.8;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.ticket-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #e5e5e5;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.ticket-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  text-transform: capitalize;
}

.ticket-status--open { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.ticket-status--in_progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.ticket-status--resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.ticket-status--closed { background: rgba(115, 115, 115, 0.15); color: #737373; }

.ticket-meta {
  display: flex;
  gap: 16rpx;
}

.ticket-user {
  font-size: 22rpx;
  color: #f59e0b;
}

.ticket-date {
  font-size: 22rpx;
  color: #525252;
}
