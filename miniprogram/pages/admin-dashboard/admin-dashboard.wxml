<wxs module="utils">
module.exports = {
  statusLabel: function(status, i) {
    if (i) {
      var map = { open: i.statusOpen, in_progress: i.statusInProgress, resolved: i.statusResolved, closed: i.statusClosed }
      if (map[status]) return map[status]
    }
    var fallback = { open: 'Open', in_progress: 'In Progress', resolved: 'Resolved', closed: 'Closed' }
    return fallback[status] || status
  },
  formatDate: function(dateStr) {
    if (!dateStr) return ''
    var d = getDate(dateStr)
    return (d.getMonth() + 1) + '/' + d.getDate() + ' ' + d.getHours() + ':' + String(d.getMinutes()).padStart(2, '0')
  },
  expandedTitle: function(card, i) {
    if (card === 'users') return i.totalUsers || 'Users'
    if (card === 'active') return i.activeUsers || 'Active Users'
    if (card === 'tickets') return i.openTickets || 'Open Tickets'
    return i.totalTickets || 'All Tickets'
  }
}
</wxs>

<view class="admin-page">
  <!-- Loading -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-header"></view>
    <view class="skeleton-card" style="height: 300rpx;"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="admin-header">
      <view class="admin-header-left">
        <text class="admin-title">{{i.title}}</text>
        <text class="admin-subtitle">{{user.username}}</text>
      </view>
      <text class="logout-btn" bind:tap="onLogout">{{i.logout}}</text>
    </view>

    <!-- Content Area -->
    <view class="admin-content">
      <!-- Dashboard Tab -->
      <view class="tab-content" wx:if="{{activeTab === 'dashboard'}}">
        <view class="stats-grid">
          <view class="stat-card {{expandedCard === 'users' ? 'stat-card--active' : ''}}" bind:tap="onStatTap" data-card="users">
            <text class="stat-value">{{stats.totalUsers}}</text>
            <text class="stat-label">{{i.totalUsers}}</text>
          </view>
          <view class="stat-card {{expandedCard === 'active' ? 'stat-card--active' : ''}}" bind:tap="onStatTap" data-card="active">
            <text class="stat-value stat-value--success">{{stats.activeUsers}}</text>
            <text class="stat-label">{{i.activeUsers}}</text>
          </view>
          <view class="stat-card {{expandedCard === 'tickets' ? 'stat-card--active' : ''}}" bind:tap="onStatTap" data-card="tickets">
            <text class="stat-value stat-value--warning">{{stats.openTickets}}</text>
            <text class="stat-label">{{i.openTickets}}</text>
          </view>
          <view class="stat-card {{expandedCard === 'all-tickets' ? 'stat-card--active' : ''}}" bind:tap="onStatTap" data-card="all-tickets">
            <text class="stat-value">{{stats.totalTickets}}</text>
            <text class="stat-label">{{i.totalTickets}}</text>
          </view>
        </view>

        <!-- Expanded Preview -->
        <view class="expanded-section" wx:if="{{expandedCard}}">
          <view class="expanded-header">
            <text class="expanded-title">{{utils.expandedTitle(expandedCard, i)}}</text>
            <text class="expanded-collapse" bind:tap="onCollapsePreview">{{i.collapse}}</text>
          </view>
          <view class="expanded-list">
            <!-- Users Preview -->
            <block wx:if="{{expandedCard === 'users' || expandedCard === 'active'}}">
              <view class="user-card" wx:for="{{users}}" wx:key="id" wx:if="{{expandedCard === 'users' || !item.disabled}}">
                <view class="user-row">
                  <view class="user-avatar">
                    <text class="avatar-letter">{{item.username[0].toUpperCase()}}</text>
                  </view>
                  <view class="user-info">
                    <view class="user-name-row">
                      <text class="user-name">{{item.username}}</text>
                      <text class="badge badge--admin" wx:if="{{item.role === 'admin'}}">Admin</text>
                      <text class="badge badge--disabled" wx:if="{{item.disabled}}">{{i.disable}}</text>
                    </view>
                    <text class="user-email">{{item.email || i.noEmail}}</text>
                  </view>
                </view>
              </view>
            </block>
            <!-- Tickets Preview -->
            <block wx:else>
              <view class="ticket-card" wx:for="{{tickets}}" wx:key="id" wx:if="{{expandedCard === 'all-tickets' || item.status === 'open' || item.status === 'in_progress'}}" bind:tap="onViewTicket" data-id="{{item.id}}">
                <view class="ticket-header">
                  <text class="ticket-title">{{item.title}}</text>
                  <text class="ticket-status ticket-status--{{item.status}}">{{utils.statusLabel(item.status, i)}}</text>
                </view>
                <view class="ticket-meta">
                  <text class="ticket-user">{{item.username}}</text>
                  <text class="ticket-date">{{utils.formatDate(item.created_at)}}</text>
                </view>
              </view>
            </block>
          </view>
        </view>

        <!-- Recent Tickets -->
        <view class="section" wx:if="{{tickets.length > 0 && !expandedCard}}">
          <text class="section-title">{{i.recentTickets}}</text>
          <view class="ticket-list">
            <view class="ticket-card" wx:for="{{tickets}}" wx:key="id" wx:if="{{index < 5}}" bind:tap="onViewTicket" data-id="{{item.id}}">
              <view class="ticket-header">
                <text class="ticket-title">{{item.title}}</text>
                <text class="ticket-status ticket-status--{{item.status}}">{{utils.statusLabel(item.status, i)}}</text>
              </view>
              <view class="ticket-meta">
                <text class="ticket-user">{{item.username}}</text>
                <text class="ticket-date">{{utils.formatDate(item.created_at)}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <!-- Users Tab -->
      <view class="tab-content" wx:if="{{activeTab === 'users'}}">
        <view class="user-list">
          <view class="user-card" wx:for="{{users}}" wx:key="id">
            <view class="user-row">
              <view class="user-avatar">
                <text class="avatar-letter">{{item.username[0].toUpperCase()}}</text>
              </view>
              <view class="user-info">
                <view class="user-name-row">
                  <text class="user-name">{{item.username}}</text>
                  <text class="badge badge--admin" wx:if="{{item.role === 'admin'}}">Admin</text>
                  <text class="badge badge--disabled" wx:if="{{item.disabled}}">{{i.disable}}</text>
                </view>
                <text class="user-email">{{item.email || i.noEmail}}</text>
                <text class="user-stats">{{item.todo_count}} {{i.tasks}} · {{item.countdown_count}} {{i.countdowns}}</text>
              </view>
            </view>
            <view class="user-actions" wx:if="{{item.id !== user.id}}">
              <text wx:if="{{item.disabled}}" class="action-btn action-btn--primary" bind:tap="onEnableUser" data-id="{{item.id}}">{{i.enable}}</text>
              <text wx:else class="action-btn" bind:tap="onDisableUser" data-id="{{item.id}}">{{i.disable}}</text>
              <text class="action-btn action-btn--danger" bind:tap="onDeleteUser" data-id="{{item.id}}">{{i.delete}}</text>
            </view>
            <view class="user-actions user-actions--self" wx:else>
              <text class="self-label">{{i.you}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Tickets Tab -->
      <view class="tab-content" wx:if="{{activeTab === 'tickets'}}">
        <!-- Filter -->
        <view class="filter-row">
          <picker mode="selector" range="{{ticketFilterLabels}}" value="{{ticketFilter}}" bindchange="onTicketFilterChange">
            <view class="filter-picker">
              <text>{{ticketFilterLabels[ticketFilter]}}</text>
              <text class="chip-arrow">&#9662;</text>
            </view>
          </picker>
        </view>
        <view class="ticket-list">
          <view class="ticket-card" wx:for="{{filteredTickets}}" wx:key="id" bind:tap="onViewTicket" data-id="{{item.id}}">
            <view class="ticket-header">
              <text class="ticket-title">{{item.title}}</text>
              <text class="ticket-status ticket-status--{{item.status}}">{{utils.statusLabel(item.status, i)}}</text>
            </view>
            <view class="ticket-body">
              <text class="ticket-desc">{{item.description || i.noDescription}}</text>
            </view>
            <view class="ticket-footer">
              <text class="ticket-user">{{item.username}}</text>
              <text class="ticket-date">{{utils.formatDate(item.created_at)}}</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{filteredTickets.length === 0}}">
          <text class="empty-text">{{i.noTickets}}</text>
        </view>
      </view>

      <!-- Config Tab -->
      <view class="tab-content" wx:if="{{activeTab === 'config'}}">
        <view class="config-card">
          <view class="config-row">
            <view class="config-info">
              <text class="config-label">{{i.userRegistration}}</text>
              <text class="config-desc">{{i.userRegistrationDesc}}</text>
            </view>
            <switch checked="{{config.registration_enabled}}" bindchange="onToggleRegistration" color="#f59e0b" />
          </view>
        </view>
      </view>

      <view class="safe-bottom"></view>
    </view>

    <!-- Bottom Tabs -->
    <view class="bottom-tabs">
      <view class="bottom-tab {{activeTab === 'dashboard' ? 'bottom-tab--active' : ''}}" bind:tap="onSwitchTab" data-tab="dashboard">
        <text class="bottom-tab-icon">&#128202;</text>
        <text class="bottom-tab-text">{{i.tabDashboard}}</text>
      </view>
      <view class="bottom-tab {{activeTab === 'users' ? 'bottom-tab--active' : ''}}" bind:tap="onSwitchTab" data-tab="users">
        <text class="bottom-tab-icon">&#128101;</text>
        <text class="bottom-tab-text">{{i.tabUsers}}</text>
      </view>
      <view class="bottom-tab {{activeTab === 'tickets' ? 'bottom-tab--active' : ''}}" bind:tap="onSwitchTab" data-tab="tickets">
        <text class="bottom-tab-icon">&#127915;</text>
        <text class="bottom-tab-text">{{i.tabTickets}}</text>
      </view>
      <view class="bottom-tab {{activeTab === 'config' ? 'bottom-tab--active' : ''}}" bind:tap="onSwitchTab" data-tab="config">
        <text class="bottom-tab-icon">&#9881;</text>
        <text class="bottom-tab-text">{{i.tabConfig}}</text>
      </view>
    </view>
  </block>

  <!-- Ticket Detail Modal -->
  <modal show="{{showTicketDetail}}" title="{{i.ticketDetails}}" hideFooter="{{true}}" bind:close="onCloseTicketDetail">
    <view class="ticket-detail" wx:if="{{currentTicket}}">
      <view class="detail-row">
        <text class="detail-label">{{i.detailTitle}}</text>
        <text class="detail-value">{{currentTicket.title}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">{{i.detailFrom}}</text>
        <text class="detail-value">{{currentTicket.username}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">{{i.detailStatus}}</text>
        <text class="ticket-status ticket-status--{{currentTicket.status}}">{{utils.statusLabel(currentTicket.status, i)}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">{{i.detailDescription}}</text>
        <text class="detail-value detail-value--block">{{currentTicket.description || i.noDescription}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">{{i.reply}}</text>
        <textarea class="reply-input" placeholder="{{i.replyPlaceholder}}" value="{{replyText}}" bindinput="onReplyInput" maxlength="2000"></textarea>
      </view>
      <view class="detail-actions">
        <text class="action-btn action-btn--primary" bind:tap="onUpdateStatus" data-status="in_progress">{{i.inProgress}}</text>
        <text class="action-btn action-btn--success" bind:tap="onUpdateStatus" data-status="resolved">{{i.resolve}}</text>
        <text class="action-btn action-btn--danger" bind:tap="onDeleteTicket">{{i.delete}}</text>
      </view>
      <view class="detail-close">
        <text class="action-btn" bind:tap="onCloseTicketDetail">{{i.close}}</text>
      </view>
    </view>
  </modal>
</view>
