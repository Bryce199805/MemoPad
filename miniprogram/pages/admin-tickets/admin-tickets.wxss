/* Admin Tickets Page - Orange Theme */
.tickets-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
  background: linear-gradient(180deg, #1a1207 0%, #0a0a0a 100%);
}

/* Loading */
.loading-skeleton .skeleton-item {
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f59e0b;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.filter-chip {
  font-size: 22rpx;
  color: #737373;
  padding: 10rpx 18rpx;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 18rpx;
}

.filter-chip--active {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ticket-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.ticket-card:active {
  opacity: 0.8;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.ticket-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  flex: 1;
}

.ticket-body {
  margin-bottom: 10rpx;
}

.ticket-desc {
  font-size: 24rpx;
  color: #737373;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
}

.ticket-user {
  font-size: 22rpx;
  color: #f59e0b;
}

.ticket-date {
  font-size: 22rpx;
  color: #404040;
}

/* Status Badge */
.ticket-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  text-transform: capitalize;
}

.ticket-status--open { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.ticket-status--in_progress { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.ticket-status--resolved { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
.ticket-status--closed, .ticket-status--muted { background: rgba(115, 115, 115, 0.15); color: #737373; }
.ticket-status--high { background: rgba(239, 68, 68, 0.15); color: #ef4444; }
.ticket-status--medium { background: rgba(245, 158, 11, 0.15); color: #f59e0b; }
.ticket-status--low { background: rgba(34, 197, 94, 0.15); color: #22c55e; }

/* Detail Modal */
.ticket-detail {
  padding: 0 8rpx;
}

.detail-row {
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #525252;
  display: block;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: #e5e5e5;
}

.detail-value--block {
  display: block;
  line-height: 1.5;
}

.reply-input {
  width: 100%;
  min-height: 140rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12rpx;
  color: #e5e5e5;
  font-size: 26rpx;
  box-sizing: border-box;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  color: #737373;
}

.action-btn--primary {
  background: rgba(245, 158, 11, 0.12);
  color: #f59e0b;
}

.action-btn--success {
  background: rgba(34, 197, 94, 0.12);
  color: #22c55e;
}

.action-btn--danger {
  background: rgba(239, 68, 68, 0.12);
  color: #ef4444;
}

.action-btn:active {
  opacity: 0.7;
}

/* Empty */
.empty-full {
  padding: 60rpx 0;
}
