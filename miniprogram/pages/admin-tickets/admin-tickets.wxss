/* Tickets Page */
.tickets-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

/* Loading */
.loading-skeleton .skeleton-item {
  height: 160rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

/* Filter Bar */
.filter-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.filter-chip {
  font-size: 24rpx;
  color: var(--text-secondary);
  padding: 12rpx 20rpx;
  background: var(--bg-tertiary);
  border-radius: 20rpx;
}

.filter-chip--active {
  background: var(--accent-primary);
  color: #ffffff;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ticket-card {
  padding: 24rpx !important;
}

.ticket-card:active {
  opacity: 0.8;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ticket-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.ticket-body {
  margin-bottom: 12rpx;
}

.ticket-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
}

.ticket-user {
  font-size: 22rpx;
  color: var(--accent-primary);
}

.ticket-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* Detail Modal */
.ticket-detail {
  padding: 0 8rpx;
}

.detail-row {
  margin-bottom: 20rpx;
}

.detail-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.detail-value--block {
  display: block;
  line-height: 1.5;
}

.reply-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.detail-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid var(--border-subtle);
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  background: var(--bg-tertiary);
  color: var(--text-secondary);
}

.action-btn--primary {
  background: rgba(99, 102, 241, 0.15);
  color: var(--accent-primary);
}

.action-btn--success {
  background: rgba(34, 197, 94, 0.15);
  color: var(--success);
}

.action-btn--danger {
  background: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

.action-btn:active {
  opacity: 0.7;
}

/* Empty */
.empty-full {
  padding: 60rpx 0;
}
