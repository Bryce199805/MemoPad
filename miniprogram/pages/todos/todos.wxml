<wxs module="filters">
module.exports = {
  priorityIndex: function(val) {
    var map = { 'high': 0, 'medium': 1, 'low': 2 };
    return map[val] !== undefined ? map[val] : 1;
  },
  categoryIndex: function(catId, categories) {
    var id = (catId && typeof catId === 'object') ? catId.id : catId;
    for (var i = 0; i < categories.length; i++) {
      if (categories[i].id === id) return i;
    }
    return 0;
  },
  categoryName: function(catId, categories) {
    var id = (catId && typeof catId === 'object') ? catId.id : catId;
    for (var i = 0; i < categories.length; i++) {
      if (categories[i].id === id) return categories[i].name;
    }
    return '';
  },
  isSelected: function(id, selectedIds) {
    for (var i = 0; i < selectedIds.length; i++) {
      if (selectedIds[i] === id) return true;
    }
    return false;
  }
};
</wxs>

<view class="todos-page">
  <!-- Loading Skeleton -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-header"></view>
    <view class="skeleton-filters"></view>
    <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="todos-header">
      <view class="todos-header-left">
        <text class="todos-title">{{i.title}}</text>
        <text class="todos-summary">
          <text class="summary-pending">{{pendingCount}} {{i.pending}}</text>
          <text class="summary-dot">·</text>
          <text class="summary-done">{{completedCount}} {{i.completed}}</text>
        </text>
      </view>
      <view class="header-btns">
        <view class="select-toggle-btn {{selectMode ? 'select-toggle-btn--active' : ''}}" bind:tap="onToggleSelectMode">
          <text>{{selectMode ? '✕' : '☑'}}</text>
        </view>
        <view class="add-btn" bind:tap="onAddTask">
          <text class="add-icon">+</text>
          <text class="add-text">{{i.add}}</text>
        </view>
      </view>
    </view>

    <!-- Filters Bar -->
    <view class="filters-bar glass-card">
      <view class="search-box">
        <text class="search-icon">🔍</text>
        <input class="search-input" placeholder="{{i.search}}" placeholder-style="color: var(--text-muted)" value="{{searchText}}" bindinput="onSearchInput" />
        <text wx:if="{{searchText}}" class="search-clear" bind:tap="onSearchClear">✕</text>
      </view>

      <view class="filter-row">
        <picker mode="selector" range="{{priorityLabels}}" value="{{filterPriority}}" bindchange="onPriorityChange" class="filter-picker-wrap">
          <view class="filter-chip {{filterPriority > 0 ? 'filter-chip--active' : ''}}">
            <text>{{priorityLabels[filterPriority]}}</text>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>

        <picker mode="selector" range="{{statusLabels}}" value="{{filterStatus}}" bindchange="onStatusChange" class="filter-picker-wrap">
          <view class="filter-chip {{filterStatus > 0 ? 'filter-chip--active' : ''}}">
            <text>{{statusLabels[filterStatus]}}</text>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>

        <picker wx:if="{{categoryNames.length > 0}}" mode="selector" range="{{categoryNames}}" value="{{filterCategory}}" bindchange="onCategoryChange" class="filter-picker-wrap">
          <view class="filter-chip {{filterCategory > 0 ? 'filter-chip--active' : ''}}">
            <text>{{filterCategory === 0 ? i.category : categoryNames[filterCategory]}}</text>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>
      </view>
    </view>

    <!-- Select Mode Actions -->
    <view class="select-actions" wx:if="{{selectMode}}">
      <text class="select-count">{{selectedIds.length}} {{i.selected}}</text>
      <view class="select-btns">
        <text class="select-action-btn" bind:tap="onSelectAll">{{i.all}}</text>
        <text class="select-action-btn" bind:tap="onDeselectAll">{{i.none}}</text>
        <text class="select-action-btn select-action-btn--success" bind:tap="onBatchComplete">{{i.complete}}</text>
        <text class="select-action-btn select-action-btn--danger" bind:tap="onBatchDelete">{{i.delete}}</text>
      </view>
    </view>

    <!-- Task Lists -->
    <block>
      <!-- Pinned Section -->
      <view class="section section--pinned" wx:if="{{pinned.length > 0}}">
        <view class="section-header">
          <text class="section-icon">📌</text>
          <text class="section-title-text">{{i.pinned}}</text>
          <badge text="{{pinned.length}}" variant="info"></badge>
        </view>
        <view class="glass-card glass-card--compact">
          <view wx:for="{{pinned}}" wx:key="id" class="todo-row">
            <view wx:if="{{selectMode}}" class="todo-checkbox-wrap" bind:tap="onToggleSelect" data-id="{{item.id}}">
              <view class="todo-checkbox {{filters.isSelected(item.id, selectedIds) ? 'todo-checkbox--checked' : ''}}">
                <text wx:if="{{filters.isSelected(item.id, selectedIds)}}" class="todo-check-icon">✓</text>
              </view>
            </view>
            <todo-item class="todo-item-comp" todo="{{item}}" categories="{{categories}}"
              bind:toggle="onTodoToggle" bind:edit="onTodoEdit"
              bind:delete="onTodoDelete" bind:pin="onTodoPin"
              bind:menuopen="onTodoMenuOpen">
            </todo-item>
          </view>
        </view>
      </view>

      <!-- Regular Tasks Section -->
      <view class="section" wx:if="{{regular.length > 0}}">
        <view class="section-header" wx:if="{{pinned.length > 0}}">
          <text class="section-title-text">{{i.allTasks}}</text>
          <badge text="{{regular.length}}" variant="info"></badge>
        </view>
        <view class="glass-card glass-card--compact">
          <view wx:for="{{regular}}" wx:key="id" class="todo-row">
            <view wx:if="{{selectMode}}" class="todo-checkbox-wrap" bind:tap="onToggleSelect" data-id="{{item.id}}">
              <view class="todo-checkbox {{filters.isSelected(item.id, selectedIds) ? 'todo-checkbox--checked' : ''}}">
                <text wx:if="{{filters.isSelected(item.id, selectedIds)}}" class="todo-check-icon">✓</text>
              </view>
            </view>
            <todo-item class="todo-item-comp" todo="{{item}}" categories="{{categories}}"
              bind:toggle="onTodoToggle" bind:edit="onTodoEdit"
              bind:delete="onTodoDelete" bind:pin="onTodoPin"
              bind:menuopen="onTodoMenuOpen">
            </todo-item>
          </view>
        </view>
      </view>

      <!-- Completed Section -->
      <view class="section completed-section" wx:if="{{completed.length > 0}}">
        <view class="section-header section-header--completed" bind:tap="onToggleCompleted">
          <text class="collapse-arrow {{completedExpanded ? 'collapse-arrow--open' : ''}}">▶</text>
          <text class="section-title-text section-title-text--muted">{{i.completed}}</text>
          <badge text="{{completed.length}}" variant="success"></badge>
          <view class="clear-btn" catchtap="onClearCompleted">
            <text class="clear-text">{{i.clearCompleted}}</text>
          </view>
        </view>
        <view class="glass-card glass-card--compact" wx:if="{{completedExpanded}}">
          <view wx:for="{{completed}}" wx:key="id" class="todo-row">
            <view wx:if="{{selectMode}}" class="todo-checkbox-wrap" bind:tap="onToggleSelect" data-id="{{item.id}}">
              <view class="todo-checkbox {{filters.isSelected(item.id, selectedIds) ? 'todo-checkbox--checked' : ''}}">
                <text wx:if="{{filters.isSelected(item.id, selectedIds)}}" class="todo-check-icon">✓</text>
              </view>
            </view>
            <todo-item class="todo-item-comp" todo="{{item}}" categories="{{categories}}"
              bind:toggle="onTodoToggle" bind:edit="onTodoEdit"
              bind:delete="onTodoDelete" bind:pin="onTodoPin"
              bind:menuopen="onTodoMenuOpen">
            </todo-item>
          </view>
        </view>
      </view>

      <!-- Empty State: no tasks at all -->
      <view class="empty-full" wx:if="{{todos.length === 0}}">
        <empty-state
          icon="📋"
          title="{{i.noTasks}}"
          description="{{i.tapToAdd}}">
        </empty-state>
      </view>

      <!-- Empty State: filters produced no results -->
      <view class="empty-full" wx:if="{{todos.length > 0 && pinned.length === 0 && regular.length === 0 && (completed.length === 0 || !completedExpanded)}}">
        <empty-state
          icon="🔍"
          title="{{i.noMatches}}"
          description="{{i.tryFilters}}">
        </empty-state>
      </view>
    </block>

    <!-- Form Modal -->
    <modal show="{{showFormModal}}" title="{{formTitle}}" bind:close="onCloseModal" bind:confirm="onFormSave">
      <view class="form-body">
        <view class="form-group">
          <text class="form-label">{{i.content}}</text>
          <textarea class="form-textarea form-input" placeholder="{{i.contentPlaceholder}}" placeholder-style="color: var(--text-muted)"
            value="{{form.content}}" bindinput="onFormContentInput" maxlength="500" auto-height></textarea>
        </view>

        <view class="form-group">
          <text class="form-label">{{i.priority}}</text>
          <picker mode="selector" range="{{[i.high, i.medium, i.low]}}" value="{{formPriorityIdx}}" bindchange="onFormPriorityChange">
            <view class="form-picker">
              <view class="form-picker-left">
                <view class="priority-dot priority-dot--{{form.priority}}"></view>
                <text class="form-picker-text">{{formPriorityLabel}}</text>
              </view>
              <text class="chip-arrow">▾</text>
            </view>
          </picker>
        </view>

        <view class="form-group" wx:if="{{categoryNames.length > 0}}">
          <text class="form-label">{{i.categoryOptional}}</text>
          <picker mode="selector" range="{{formCategoryOptions}}" value="{{formCategoryIdx}}" bindchange="onFormCategoryChange">
            <view class="form-picker">
              <view class="form-picker-left">
                <text class="form-picker-text">{{formCategoryOptions[formCategoryIdx]}}</text>
              </view>
              <text class="chip-arrow">▾</text>
            </view>
          </picker>
        </view>
      </view>
    </modal>

    <view class="safe-bottom"></view>
  </block>
</view>
