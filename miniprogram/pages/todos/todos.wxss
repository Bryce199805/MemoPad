/* Todos Page */
.todos-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

/* Loading Skeleton */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 300rpx;
  background: var(--bg-tertiary);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-filters {
  height: 160rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 32rpx;
  animation: skeleton-pulse 1.5s infinite;
  animation-delay: 0.1s;
}

.skeleton-item {
  height: 120rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-item:nth-child(2) { animation-delay: 0.15s; }
.skeleton-item:nth-child(3) { animation-delay: 0.3s; }

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* Header */
.todos-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.todos-header-left {
  flex: 1;
  min-width: 0;
}

.todos-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
  display: block;
}

.todos-summary {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.summary-pending {
  color: var(--text-secondary);
}

.summary-dot {
  margin: 0 8rpx;
}

.summary-done {
  color: var(--success);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.add-btn:active {
  opacity: 0.85;
}

.add-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.add-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.header-btns {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.select-toggle-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.select-toggle-btn--active {
  background: rgba(239, 68, 68, 0.15);
  border-color: rgba(239, 68, 68, 0.3);
  color: var(--danger);
}

/* Filters Bar */
.filters-bar {
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}

.search-box:focus-within {
  border-color: var(--accent-primary);
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.filter-picker-wrap {
  flex: 1;
  min-width: 0;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  padding: 10rpx 8rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 22rpx;
  color: var(--text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.filter-chip--active {
  background: rgba(99, 102, 241, 0.12);
  border-color: rgba(99, 102, 241, 0.3);
  color: var(--accent-primary);
}

.chip-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* Select Mode Actions */
.select-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(99, 102, 241, 0.08);
  border: 1px solid rgba(99, 102, 241, 0.2);
  border-radius: var(--radius-md);
  margin-bottom: 24rpx;
}

.select-count {
  font-size: 24rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

.select-btns {
  display: flex;
  gap: 20rpx;
}

.select-action-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
  padding: 8rpx 16rpx;
}

.select-action-btn:active {
  opacity: 0.6;
}

.select-action-btn--danger {
  color: var(--danger);
}

.select-action-btn--success {
  color: var(--success);
}

/* Sections */
.section {
  margin-bottom: 24rpx;
}

.section:first-of-type {
  margin-top: 8rpx;
}

.section--pinned {
  margin-top: 0;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.section-header--completed {
  cursor: pointer;
}

.section-icon {
  font-size: 28rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.section-title-text--muted {
  color: var(--text-muted);
}

.collapse-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
  transition: transform 0.2s;
}

.collapse-arrow--open {
  transform: rotate(90deg);
}

.clear-btn {
  padding: 8rpx 20rpx;
  background: rgba(239, 68, 68, 0.1);
  border-radius: var(--radius-sm);
}

.clear-text {
  font-size: 22rpx;
  color: var(--danger);
  font-weight: 500;
}

.clear-btn:active {
  opacity: 0.6;
}

/* Todo Row with Select Checkbox */
.todo-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.todo-checkbox-wrap {
  flex-shrink: 0;
  padding: 12rpx;
}

.todo-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  border: 2px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}

.todo-checkbox--checked {
  background: var(--accent-primary);
  border-color: var(--accent-primary);
}

.todo-check-icon {
  font-size: 24rpx;
  color: #ffffff;
}

/* Completed Section */
.completed-section .glass-card--compact {
  animation: slide-down 0.2s ease;
}

@keyframes slide-down {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Empty Full Page */
.empty-full {
  padding: 80rpx 0;
}

/* Glass Card overrides */
.glass-card--compact {
  padding: 12rpx 24rpx;
}

/* Form Body inside Modal */
.form-body {
  padding: 0 8rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx 28rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: var(--accent-primary);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
}

.form-picker:active {
  border-color: var(--accent-primary);
}

.form-picker-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-picker--half {
  flex: 1;
  min-width: 0;
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot--high { background: var(--danger); }
.priority-dot--medium { background: var(--warning); }
.priority-dot--low { background: var(--success); }

.form-row-label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

/* Toggle Switch */
.toggle-switch {
  width: 88rpx;
  height: 48rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 99rpx;
  padding: 4rpx;
  box-sizing: border-box;
  transition: all 0.2s;
}

.toggle-switch--on {
  background: var(--accent-primary);
  border-color: var(--accent-primary);
}

.toggle-knob {
  width: 36rpx;
  height: 36rpx;
  background: #ffffff;
  border-radius: 50%;
  transition: transform 0.2s;
}

.toggle-switch--on .toggle-knob {
  transform: translateX(40rpx);
}

.date-time-row {
  display: flex;
  gap: 16rpx;
}
