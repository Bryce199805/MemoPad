/* Admin Users Page - Orange Theme */
.admin-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
  background: linear-gradient(180deg, #1a1207 0%, #0a0a0a 100%);
}

/* Loading */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 200rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.skeleton-item {
  height: 120rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
}

/* Header */
.page-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #f59e0b;
}

.page-count {
  font-size: 24rpx;
  color: #525252;
}

/* User List */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.user-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-letter {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1207;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 4rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
}

.badge {
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.badge--admin {
  background: rgba(245, 158, 11, 0.15);
  color: #f59e0b;
}

.badge--disabled {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.user-email {
  font-size: 22rpx;
  color: #525252;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-stats {
  font-size: 20rpx;
  color: #404040;
  margin-top: 2rpx;
  display: block;
}

/* Actions */
.user-actions {
  display: flex;
  gap: 12rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.04);
}

.user-actions--self {
  justify-content: flex-end;
}

.self-label {
  font-size: 22rpx;
  color: #525252;
  font-style: italic;
}

.action-btn {
  font-size: 22rpx;
  color: #737373;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.04);
}

.action-btn:active {
  opacity: 0.7;
}

.action-btn--primary {
  color: #f59e0b;
  background: rgba(245, 158, 11, 0.1);
}

.action-btn--danger {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.1);
}

/* Empty */
.empty-full {
  padding: 60rpx 0;
}
