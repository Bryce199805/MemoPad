<view class="admin-page">
  <!-- Loading -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-header"></view>
    <view class="skeleton-item" wx:for="{{[1,2,3,4,5]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="page-header">
      <text class="page-title">Users</text>
      <text class="page-count">{{users.length}} total</text>
    </view>

    <!-- User List -->
    <view class="user-list">
      <view class="user-card" wx:for="{{users}}" wx:key="id">
        <view class="user-row">
          <view class="user-avatar">
            <text class="avatar-letter">{{item.username[0].toUpperCase()}}</text>
          </view>
          <view class="user-info">
            <view class="user-name-row">
              <text class="user-name">{{item.username}}</text>
              <text class="badge badge--admin" wx:if="{{item.role === 'admin'}}">Admin</text>
              <text class="badge badge--disabled" wx:if="{{item.disabled}}">Disabled</text>
            </view>
            <text class="user-email">{{item.email || 'No email'}}</text>
            <text class="user-stats">{{item.todo_count}} tasks · {{item.countdown_count}} countdowns</text>
          </view>
        </view>
        <view class="user-actions" wx:if="{{item.id !== currentUser.id}}">
          <text wx:if="{{item.disabled}}" class="action-btn action-btn--primary" bind:tap="onEnableUser" data-id="{{item.id}}">Enable</text>
          <text wx:else class="action-btn" bind:tap="onDisableUser" data-id="{{item.id}}">Disable</text>
          <text class="action-btn action-btn--danger" bind:tap="onDeleteUser" data-id="{{item.id}}">Delete</text>
        </view>
        <view class="user-actions user-actions--self" wx:else>
          <text class="self-label">(This is you)</text>
        </view>
      </view>
    </view>

    <!-- Empty -->
    <view class="empty-full" wx:if="{{users.length === 0}}">
      <empty-state icon="👥" title="No users" description="No users found"></empty-state>
    </view>

    <view class="safe-bottom"></view>
  </block>
</view>
