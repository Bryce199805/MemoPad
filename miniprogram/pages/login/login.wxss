.login-page {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
}

.bg-gradient {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #0a0a0a 0%, #111128 40%, #1a0a2e 70%, #0a0a0a 100%);
  z-index: 0;
}

.login-container {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
  padding-top: 180rpx;
}

/* Logo */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}

.logo-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(99, 102, 241, 0.3);
}

.logo-check {
  font-size: 60rpx;
  color: #ffffff;
  font-weight: 700;
}

.app-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.app-tagline {
  font-size: 26rpx;
  color: #888888;
  margin-top: 8rpx;
}

/* Tab Switcher */
.tab-switcher {
  display: flex;
  position: relative;
  width: 100%;
  max-width: 500rpx;
  background: var(--bg-tertiary, #1a1a1a);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 48rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  color: #666666;
  position: relative;
  z-index: 1;
  transition: color 0.25s ease;
}

.tab-active {
  color: #ffffff;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  top: 6rpx;
  left: 0;
  width: 50%;
  height: calc(100% - 12rpx);
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 12rpx;
  transition: left 0.3s ease;
  box-shadow: 0 2rpx 12rpx rgba(99, 102, 241, 0.3);
}

/* Form */
.form {
  width: 100%;
  max-width: 500rpx;
}

.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #a0a0a0;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 28rpx 28rpx;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #6366f1;
  background: rgba(99, 102, 241, 0.05);
}

.input-placeholder {
  color: #555555;
}

/* Error */
.error-box {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.25);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 28rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  line-height: 1.5;
}

/* Submit Button */
.submit-btn {
  width: 100%;
  padding: 24rpx 0;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(99, 102, 241, 0.3);
  line-height: 1;
}

.submit-btn::after {
  border: none;
}

.btn-disabled {
  opacity: 0.6;
}

/* Loading Spinner */
.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.2);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: spin 0.7s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}
