<view class="login-page">
  <!-- Background gradient -->
  <view class="bg-gradient"></view>

  <view class="login-container">
    <!-- Logo -->
    <view class="logo-area">
      <view class="logo-icon">
        <text class="logo-check">✓</text>
      </view>
      <text class="app-name">MemoPad</text>
      <text class="app-tagline">{{i.tagline}}</text>
    </view>

    <!-- Tab switcher -->
    <view class="tab-switcher">
      <view class="tab-item {{mode === 'login' ? 'tab-active' : ''}}" data-mode="login" bindtap="switchMode">
        <text>{{i.signIn}}</text>
      </view>
      <view class="tab-item {{mode === 'register' ? 'tab-active' : ''}}" data-mode="register" bindtap="switchMode">
        <text>{{i.signUp}}</text>
      </view>
      <view class="tab-indicator" style="left: {{mode === 'login' ? '0%' : '50%'}}"></view>
    </view>

    <!-- Form -->
    <view class="form">
      <!-- Error display - moved to top -->
      <view class="error-box" wx:if="{{error}}">
        <text class="error-text">{{error}}</text>
        <text class="error-close" bind:tap="clearError">✕</text>
      </view>

      <view class="form-group">
        <text class="form-label">{{i.username}}</text>
        <input
          class="form-input"
          type="text"
          placeholder="{{i.usernamePlaceholder}}"
          placeholder-class="input-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
        />
      </view>

      <view class="form-group">
        <text class="form-label">{{i.password}}</text>
        <input
          class="form-input"
          password
          placeholder="{{i.passwordPlaceholder}}"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
        />
      </view>

      <view class="form-group" wx:if="{{mode === 'register'}}">
        <text class="form-label">{{i.email}}</text>
        <input
          class="form-input"
          type="text"
          placeholder="your@email.com"
          placeholder-class="input-placeholder"
          value="{{email}}"
          bindinput="onEmailInput"
        />
      </view>

      <!-- Submit button -->
      <button class="submit-btn {{loading ? 'btn-disabled' : ''}}" bindtap="submit" disabled="{{loading}}">
        <text wx:if="{{!loading}}">{{mode === 'login' ? i.signIn : i.createAccount}}</text>
        <view class="loading-spinner" wx:else></view>
      </button>
    </view>
  </view>
</view>
