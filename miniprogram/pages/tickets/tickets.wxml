<wxs module="utils">
module.exports = {
  statusVariant: function(status) {
    var map = { open: 'danger', in_progress: 'warning', resolved: 'success', closed: 'info' }
    return map[status] || 'info'
  },
  statusLabel: function(status, i) {
    var map = { open: i.statusOpen, in_progress: i.statusInProgress, resolved: i.statusResolved, closed: i.statusClosed }
    return map[status] || status
  },
  priorityLabel: function(priority, i) {
    var map = { high: i.priorityHigh, medium: i.priorityMedium, low: i.priorityLow }
    return map[priority] || priority
  },
  formatDate: function(dateStr) {
    if (!dateStr) return ''
    var d = getDate(dateStr)
    return (d.getMonth() + 1) + '/' + d.getDate() + ' ' + d.getHours() + ':' + String(d.getMinutes()).padStart(2, '0')
  }
}
</wxs>

<view class="tickets-page">
  <!-- Loading -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="page-header">
      <text class="page-title">{{i.title}}</text>
      <view class="add-btn" bind:tap="onOpenModal">
        <text class="add-icon">+</text>
        <text class="add-text">{{i.new}}</text>
      </view>
    </view>

    <!-- Ticket List -->
    <view class="ticket-list" wx:if="{{tickets.length > 0}}">
      <view class="ticket-card glass-card" wx:for="{{tickets}}" wx:key="id" bind:tap="onViewTicket" data-id="{{item.id}}">
        <view class="ticket-header">
          <view class="ticket-title-row">
            <text class="ticket-title">{{item.title}}</text>
            <view class="unread-dot" wx:if="{{item.replies && item.replies.length > 0 && !item.reply_read_at}}"></view>
          </view>
          <badge text="{{utils.statusLabel(item.status, i)}}" variant="{{utils.statusVariant(item.status)}}"></badge>
        </view>
        <view class="ticket-footer">
          <badge text="{{utils.priorityLabel(item.priority, i)}}" variant="{{item.priority === 'high' ? 'danger' : item.priority === 'low' ? 'success' : 'warning'}}"></badge>
          <text class="ticket-date">{{utils.formatDate(item.created_at)}}</text>
          <text class="new-reply-badge" wx:if="{{item.replies && item.replies.length > 0 && !item.reply_read_at}}">{{i.newReply}}</text>
        </view>
      </view>
    </view>

    <!-- Empty -->
    <view class="empty-full" wx:if="{{tickets.length === 0}}">
      <empty-state icon="💬" title="{{i.noTickets}}" description="{{i.noTicketsDesc}}"></empty-state>
    </view>

    <view class="safe-bottom"></view>
  </block>

  <!-- Ticket Detail Modal -->
  <view class="detail-overlay" wx:if="{{showDetail}}">
    <!-- Background tap area to close -->
    <view class="detail-overlay-bg" bind:tap="onCloseDetail"></view>
    <view class="detail-modal">
      <view class="detail-modal-header">
        <text class="detail-modal-title">{{i.ticketDetails}}</text>
        <text class="detail-close-btn" bind:tap="onCloseDetail">✕</text>
      </view>
      <scroll-view scroll-y class="detail-modal-body" wx:if="{{selectedTicket}}">
        <view class="detail-field">
          <text class="detail-label">{{i.titleField}}</text>
          <text class="detail-value">{{selectedTicket.title}}</text>
        </view>
        <view class="detail-field">
          <text class="detail-label">{{i.detailStatus}}</text>
          <badge text="{{utils.statusLabel(selectedTicket.status, i)}}" variant="{{utils.statusVariant(selectedTicket.status)}}"></badge>
        </view>
        <view class="detail-field">
          <text class="detail-label">{{i.priority}}</text>
          <badge text="{{utils.priorityLabel(selectedTicket.priority, i)}}" variant="{{selectedTicket.priority === 'high' ? 'danger' : selectedTicket.priority === 'low' ? 'success' : 'warning'}}"></badge>
        </view>
        <view class="detail-field" wx:if="{{selectedTicket.description}}">
          <text class="detail-label">{{i.description}}</text>
          <text class="detail-value detail-desc">{{selectedTicket.description}}</text>
        </view>
        <view class="detail-field">
          <text class="detail-label">{{i.submitted}}</text>
          <text class="detail-value">{{utils.formatDate(selectedTicket.created_at)}}</text>
        </view>

        <!-- Reply Thread -->
        <view class="detail-field detail-replies">
          <text class="detail-label">{{i.replies}}</text>
          <view wx:if="{{!selectedTicket.replies || selectedTicket.replies.length === 0}}" class="no-replies-text">
            <text>{{i.noReplies}}</text>
          </view>
          <view wx:for="{{selectedTicket.replies}}" wx:key="id" class="reply-item {{item.is_admin ? 'reply-item--admin' : 'reply-item--user'}}">
            <view class="reply-item-header">
              <text class="{{item.is_admin ? 'reply-admin-label' : 'reply-user-label'}}">{{item.is_admin ? i.adminReply : i.userReply}}</text>
              <text class="reply-time">{{utils.formatDate(item.created_at)}}</text>
            </view>
            <text class="reply-content">{{item.content}}</text>
          </view>
        </view>
      </scroll-view>

      <!-- Reply Input: outside scroll-view to avoid native component layer issues -->
      <view class="reply-area" wx:if="{{selectedTicket && selectedTicket.status !== 'closed'}}">
        <textarea class="reply-input" placeholder="{{i.replyPlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{replyText}}" bindinput="onReplyInput" maxlength="2000" fixed="{{true}}"></textarea>
        <view class="reply-send-row">
          <view class="reply-send-btn" bind:tap="onSendReply">
            <text>{{i.sendReply}}</text>
          </view>
        </view>
      </view>

      <view class="detail-modal-footer">
        <view class="close-ticket-btn" wx:if="{{selectedTicket && (selectedTicket.status === 'open' || selectedTicket.status === 'in_progress' || selectedTicket.status === 'resolved')}}" bind:tap="onCloseTicket">
          <text>{{i.closeTicket}}</text>
        </view>
        <view class="detail-done-btn" bind:tap="onCloseDetail">
          <text>{{i.close}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Submit Modal -->
  <modal show="{{showModal}}" title="{{i.new}}" bind:close="onCloseModal" bind:confirm="onSubmit">
    <view class="form-body">
      <view class="form-group">
        <text class="form-label">{{i.titleField}}</text>
        <input class="form-input" placeholder="{{i.titlePlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{form.title}}" bindinput="onTitleInput" maxlength="200" />
      </view>
      <view class="form-group">
        <text class="form-label">{{i.description}}</text>
        <textarea class="form-textarea" placeholder="{{i.descPlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{form.description}}" bindinput="onDescInput" maxlength="2000"></textarea>
      </view>
      <view class="form-group">
        <text class="form-label">{{i.priority}}</text>
        <picker mode="selector" range="{{[i.priorityHigh, i.priorityMedium, i.priorityLow]}}" value="{{priorityIdx}}" bindchange="onPriorityChange">
          <view class="form-picker">
            <text>{{[i.priorityHigh, i.priorityMedium, i.priorityLow][priorityIdx]}}</text>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>
      </view>
    </view>
  </modal>
</view>
