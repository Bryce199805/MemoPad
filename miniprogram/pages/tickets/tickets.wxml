<wxs module="utils">
module.exports = {
  statusVariant: function(status) {
    var map = { open: 'danger', in_progress: 'warning', resolved: 'success', closed: 'info' }
    return map[status] || 'info'
  },
  statusLabel: function(status, i) {
    var map = { open: i.statusOpen, in_progress: i.statusInProgress, resolved: i.statusResolved, closed: i.statusClosed }
    return map[status] || status
  },
  priorityLabel: function(priority, i) {
    var map = { high: i.priorityHigh, medium: i.priorityMedium, low: i.priorityLow }
    return map[priority] || priority
  },
  formatDate: function(dateStr) {
    if (!dateStr) return ''
    var d = getDate(dateStr)
    return (d.getMonth() + 1) + '/' + d.getDate() + ' ' + d.getHours() + ':' + String(d.getMinutes()).padStart(2, '0')
  }
}
</wxs>

<view class="tickets-page">
  <!-- Loading -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="page-header">
      <text class="page-title">{{i.title}}</text>
      <view class="add-btn" bind:tap="onOpenModal">
        <text class="add-icon">+</text>
        <text class="add-text">{{i.new}}</text>
      </view>
    </view>

    <!-- Ticket List -->
    <view class="ticket-list" wx:if="{{tickets.length > 0}}">
      <view class="ticket-card glass-card" wx:for="{{tickets}}" wx:key="id" bind:tap="onViewTicket" data-id="{{item.id}}">
        <view class="ticket-header">
          <view class="ticket-title-row">
            <text class="ticket-title">{{item.title}}</text>
            <view class="unread-dot" wx:if="{{item.reply && !item.reply_read_at}}"></view>
          </view>
          <badge text="{{utils.statusLabel(item.status, i)}}" variant="{{utils.statusVariant(item.status)}}"></badge>
        </view>
        <view class="ticket-body" wx:if="{{item.description}}">
          <text class="ticket-desc">{{item.description}}</text>
        </view>
        <view class="ticket-footer">
          <badge text="{{utils.priorityLabel(item.priority, i)}}" variant="{{item.priority === 'high' ? 'danger' : item.priority === 'low' ? 'success' : 'warning'}}"></badge>
          <text class="ticket-date">{{utils.formatDate(item.created_at)}}</text>
        </view>
        <view class="ticket-reply" wx:if="{{item.reply}}">
          <view class="reply-label-row">
            <text class="reply-label">{{i.adminReply}}</text>
            <text class="new-reply-badge" wx:if="{{!item.reply_read_at}}">{{i.newReply}}</text>
          </view>
          <text class="reply-text">{{item.reply}}</text>
        </view>
      </view>
    </view>

    <!-- Empty -->
    <view class="empty-full" wx:if="{{tickets.length === 0}}">
      <empty-state icon="💬" title="{{i.noTickets}}" description="{{i.noTicketsDesc}}"></empty-state>
    </view>

    <view class="safe-bottom"></view>
  </block>

  <!-- Submit Modal -->
  <modal show="{{showModal}}" title="{{i.new}}" bind:close="onCloseModal" bind:confirm="onSubmit">
    <view class="form-body">
      <view class="form-group">
        <text class="form-label">{{i.titleField}}</text>
        <input class="form-input" placeholder="{{i.titlePlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{form.title}}" bindinput="onTitleInput" maxlength="200" />
      </view>
      <view class="form-group">
        <text class="form-label">{{i.description}}</text>
        <textarea class="form-textarea" placeholder="{{i.descPlaceholder}}" placeholder-style="color: var(--text-muted)"
          value="{{form.description}}" bindinput="onDescInput" maxlength="2000"></textarea>
      </view>
      <view class="form-group">
        <text class="form-label">{{i.priority}}</text>
        <picker mode="selector" range="{{[i.priorityHigh, i.priorityMedium, i.priorityLow]}}" value="{{priorityIdx}}" bindchange="onPriorityChange">
          <view class="form-picker">
            <text>{{[i.priorityHigh, i.priorityMedium, i.priorityLow][priorityIdx]}}</text>
            <text class="chip-arrow">▾</text>
          </view>
        </picker>
      </view>
    </view>
  </modal>
</view>
