/* Tickets Page */
.tickets-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

.loading-skeleton .skeleton-item {
  height: 160rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.add-text {
  font-size: 24rpx;
  color: #fff;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ticket-card {
  padding: 24rpx !important;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ticket-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.ticket-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ef4444;
  flex-shrink: 0;
}

.ticket-body {
  margin-bottom: 12rpx;
}

.ticket-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ticket-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.new-reply-badge {
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
  margin-left: auto;
}

/* Form */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
}

.chip-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* Empty */
.empty-full {
  padding: 60rpx 0;
}

/* Detail Modal */
.detail-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.detail-overlay-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.detail-modal {
  position: relative;
  width: 100%;
  max-height: 86vh;
  display: flex;
  flex-direction: column;
  border-radius: 24rpx;
  overflow: hidden;
  background: #1a1a1a;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.detail-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1px solid var(--border-subtle);
}

.detail-modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.detail-close-btn {
  font-size: 36rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.detail-modal-body {
  padding: 24rpx 32rpx;
  flex: 1;
  min-height: 0;
}

/* Reply area sits between scroll-body and footer, outside scroll-view */
.reply-area {
  padding: 16rpx 32rpx;
  border-top: 1px solid var(--border-subtle);
  background: #1a1a1a;
}

.detail-field {
  margin-bottom: 24rpx;
}

.detail-label {
  font-size: 22rpx;
  font-weight: 500;
  color: var(--text-muted);
  text-transform: uppercase;
  display: block;
  margin-bottom: 8rpx;
}

.detail-value {
  font-size: 28rpx;
  color: var(--text-primary);
}

.detail-desc {
  line-height: 1.6;
  white-space: pre-wrap;
}

.detail-replies {
  padding-top: 20rpx;
  border-top: 1px solid var(--border-subtle);
}

.no-replies-text {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 12rpx 0;
}

.reply-item {
  border-radius: 0 12rpx 12rpx 0;
  padding: 16rpx 20rpx;
  margin-top: 12rpx;
}

.reply-item--admin {
  background: rgba(20, 184, 166, 0.06);
  border-left: 4rpx solid rgba(20, 184, 166, 0.4);
}

.reply-item--user {
  background: rgba(99, 102, 241, 0.06);
  border-left: 4rpx solid rgba(99, 102, 241, 0.4);
}

.reply-item-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.reply-admin-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #14b8a6;
  text-transform: uppercase;
}

.reply-user-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #6366f1;
  text-transform: uppercase;
}

.reply-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

.reply-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  white-space: pre-wrap;
  line-height: 1.5;
}

.detail-modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  border-top: 1px solid var(--border-subtle);
}

.close-ticket-btn {
  padding: 14rpx 28rpx;
  background: rgba(239, 68, 68, 0.12);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 500;
}

.close-ticket-btn:active {
  opacity: 0.7;
}

.detail-done-btn {
  padding: 14rpx 28rpx;
  background: var(--bg-tertiary);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

/* User Reply Input */
.reply-input {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.reply-send-row {
  display: flex;
  justify-content: flex-end;
  margin-top: 12rpx;
}

.reply-send-btn {
  padding: 12rpx 32rpx;
  background: rgba(99, 102, 241, 0.15);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #6366f1;
  font-weight: 500;
}

.reply-send-btn:active {
  opacity: 0.7;
}
