/* Tickets Page */
.tickets-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

.loading-skeleton .skeleton-item {
  height: 160rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

/* Header */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
}

.add-icon {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
}

.add-text {
  font-size: 24rpx;
  color: #fff;
}

/* Ticket List */
.ticket-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ticket-card {
  padding: 24rpx !important;
}

.ticket-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.ticket-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  flex: 1;
}

.ticket-title-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.unread-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ef4444;
  flex-shrink: 0;
}

.reply-label-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.new-reply-badge {
  font-size: 20rpx;
  color: #fff;
  background: #ef4444;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.ticket-body {
  margin-bottom: 12rpx;
}

.ticket-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.ticket-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ticket-date {
  font-size: 22rpx;
  color: var(--text-muted);
}

.ticket-reply {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1px solid var(--border-subtle);
}

.reply-label {
  font-size: 22rpx;
  color: var(--text-muted);
  display: block;
  margin-bottom: 8rpx;
}

.reply-text {
  font-size: 26rpx;
  color: var(--success);
  line-height: 1.5;
}

/* Form */
.form-textarea {
  width: 100%;
  min-height: 120rpx;
  padding: 16rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
  box-sizing: border-box;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: 12rpx;
  color: var(--text-primary);
  font-size: 26rpx;
}

.chip-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

/* Empty */
.empty-full {
  padding: 60rpx 0;
}
