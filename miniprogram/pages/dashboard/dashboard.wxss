/* Dashboard Page */
.dashboard {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

/* Loading Skeleton */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 300rpx;
  background: var(--bg-tertiary);
  border-radius: 16rpx;
  margin-bottom: 40rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.skeleton-card {
  height: 160rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-card:nth-child(2) { animation-delay: 0.1s; }
.skeleton-card:nth-child(3) { animation-delay: 0.2s; }
.skeleton-card:nth-child(4) { animation-delay: 0.3s; }

.skeleton-section {
  height: 300rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  animation: skeleton-pulse 1.5s infinite;
  animation-delay: 0.4s;
}

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* Header */
.header {
  margin-bottom: 40rpx;
}

.header-top {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.header-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.header-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
}

.header-date {
  font-size: 26rpx;
  color: var(--text-muted);
}

/* Stat Grid */
.stat-scroll {
  margin: 0 -32rpx;
  padding: 0 32rpx;
  white-space: nowrap;
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.stat-grid--scroll {
  display: inline-flex;
  gap: 20rpx;
}

.stat-grid--scroll .stat-card {
  min-width: 300rpx;
}

/* Expanded Preview */
.expanded-section {
  background: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 32rpx;
  animation: expand-in 0.25s ease;
}

@keyframes expand-in {
  from {
    opacity: 0;
    transform: translateY(-12rpx);
    max-height: 0;
  }
  to {
    opacity: 1;
    transform: translateY(0);
    max-height: 2000rpx;
  }
}

.expanded-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.expanded-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.expanded-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.expanded-collapse {
  font-size: 24rpx;
  color: var(--text-muted);
}

.expanded-view-all {
  font-size: 24rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

.expanded-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.expanded-countdowns {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  max-height: 600rpx;
  overflow-y: auto;
}

/* Two Column Layout */
.columns {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.column {
  flex: 1;
  min-width: 0;
}

.column-left {
  flex: 1.1;
}

.column-right {
  flex: 0.9;
}

.glass-card {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.glass-card--compact {
  padding: 12rpx 32rpx;
}

.glass-card--alert {
  border-color: rgba(239, 68, 68, 0.25);
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.06) 0%, rgba(255, 255, 255, 0.01) 100%);
}

/* Progress Section */
.progress-section {
  margin-bottom: 32rpx;
}

.progress-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.progress-rate {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
}

.progress-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

.progress-bar {
  height: 16rpx;
  background: var(--bg-tertiary);
  border-radius: 99rpx;
  overflow: hidden;
}

.progress-bar--sm {
  height: 8rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 99rpx;
  transition: width 0.5s ease;
}

.progress-stats {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.progress-stat {
  font-size: 24rpx;
  color: var(--text-muted);
}

.progress-stat-num {
  font-weight: 600;
  color: var(--text-secondary);
}

/* Priority Breakdown */
.priority-section {
  margin-bottom: 24rpx;
}

.priority-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  display: block;
}

.priority-bars {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.priority-bar-row {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.priority-bar-label {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.priority-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.priority-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-transform: capitalize;
  flex: 1;
}

.priority-count {
  font-size: 24rpx;
  color: var(--text-muted);
  font-weight: 600;
}

/* Countdown Mini List */
.countdown-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.countdown-mini {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.countdown-mini-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

/* Pinned List */
.pinned-list {
  display: flex;
  flex-direction: column;
}

.countdown-mini-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.countdown-mini-title {
  font-size: 26rpx;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.countdown-mini-days {
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* Sections */
.section {
  margin-top: 24rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-title--danger {
  color: var(--danger);
}

/* Alert Banner */
.alert-banner {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: rgba(239, 68, 68, 0.08);
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.alert-icon {
  font-size: 24rpx;
}

.alert-text {
  font-size: 26rpx;
  color: var(--danger);
  font-weight: 500;
}

/* View All Link */
.view-all-link {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1px solid var(--border-subtle);
}

.view-all-link text:first-child {
  font-size: 24rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

.view-all-link:active {
  opacity: 0.7;
}

.arrow {
  font-size: 28rpx;
  color: var(--accent-primary);
}

.view-all-link--center {
  justify-content: center;
}

/* Empty Full Page */
.empty-full {
  padding: 60rpx 0;
}

/* Text utility overrides for wxss */
.text-danger { color: var(--danger); }
.text-warning { color: var(--warning); }
.text-accent { color: var(--accent-primary); }
