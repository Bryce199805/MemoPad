/* Countdowns Page */
.countdowns-page {
  min-height: 100vh;
  padding: 32rpx;
  padding-top: 48rpx;
}

/* Loading Skeleton */
.loading-skeleton {
  padding-top: 48rpx;
}

.skeleton-header {
  height: 80rpx;
  width: 300rpx;
  background: var(--bg-tertiary);
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-stats {
  height: 140rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  animation: skeleton-pulse 1.5s infinite;
  animation-delay: 0.1s;
}

.skeleton-search {
  height: 80rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  animation: skeleton-pulse 1.5s infinite;
  animation-delay: 0.15s;
}

.skeleton-item {
  height: 200rpx;
  background: var(--bg-tertiary);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  animation: skeleton-pulse 1.5s infinite;
}

.skeleton-item:nth-child(2) { animation-delay: 0.15s; }
.skeleton-item:nth-child(3) { animation-delay: 0.3s; }

@keyframes skeleton-pulse {
  0%, 100% { opacity: 0.4; }
  50% { opacity: 0.8; }
}

/* Header */
.countdowns-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.countdowns-title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -1rpx;
}

.header-btns {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.select-btn {
  padding: 16rpx 24rpx;
  background: var(--bg-tertiary);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.select-btn--active {
  background: var(--danger);
  color: #fff;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
  border-radius: 16rpx;
  flex-shrink: 0;
}

.add-btn:active {
  opacity: 0.85;
}

.add-icon {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.add-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* Stats Row */
.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 16rpx;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.2;
}

.stat-value--upcoming {
  color: var(--accent-primary);
}

.stat-value--due-soon {
  color: var(--warning);
}

.stat-value--overdue {
  color: var(--danger);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* Search Bar */
.search-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.search-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* Priority Filter */
.filter-row {
  margin-bottom: 24rpx;
}

.filter-chips {
  display: flex;
  gap: 12rpx;
}

.filter-chip {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #737373;
}

.filter-chip:active {
  opacity: 0.8;
}

.filter-chip--active {
  background: rgba(99, 102, 241, 0.15);
  border-color: #6366f1;
  color: #6366f1;
}

.filter-chip--high.filter-chip--active {
  background: rgba(239, 68, 68, 0.15);
  border-color: #ef4444;
  color: #ef4444;
}

.filter-chip--medium.filter-chip--active {
  background: rgba(245, 158, 11, 0.15);
  border-color: #f59e0b;
  color: #f59e0b;
}

.filter-chip--low.filter-chip--active {
  background: rgba(34, 197, 94, 0.15);
  border-color: #22c55e;
  color: #22c55e;
}

/* Sections */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.section-icon {
  font-size: 28rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #e5e5e5;
  flex: 1;
}

/* Countdown List */
.countdown-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  width: 100%;
}

/* Empty */
.empty-full {
  padding: 24rpx 0;
}

/* Form */
.form-body {
  padding: 0 8rpx;
}

.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
  color: var(--text-primary);
  font-size: 28rpx;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: var(--accent-primary);
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg-tertiary);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-md);
}

.form-picker:active {
  border-color: var(--accent-primary);
}

.form-picker-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.form-picker-text {
  font-size: 28rpx;
  color: var(--text-primary);
}

.form-picker--half {
  flex: 1;
  min-width: 0;
}

.chip-arrow {
  font-size: 20rpx;
  color: var(--text-muted);
}

.priority-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
}

.priority-dot--high { background: var(--danger); }
.priority-dot--medium { background: var(--warning); }
.priority-dot--low { background: var(--success); }

.date-time-row {
  display: flex;
  gap: 16rpx;
}

/* Select Mode */
.select-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: var(--bg-secondary);
  border-radius: var(--radius-lg);
}

.select-count {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.select-btns {
  display: flex;
  gap: 24rpx;
}

.select-action-btn {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.select-action-btn:active {
  opacity: 0.6;
}

.select-action-btn--danger {
  color: var(--danger);
}

/* Countdown Row with Checkbox */
.countdown-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 16rpx;
}

.countdown-card-wrap {
  flex: 1;
  min-width: 0;
  display: block;
}

.countdown-checkbox-wrap {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-top: 4rpx;
}

.countdown-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.countdown-checkbox--checked {
  background: #6366f1;
  border-color: #6366f1;
}

.countdown-check-icon {
  color: #fff;
  font-size: 24rpx;
}
