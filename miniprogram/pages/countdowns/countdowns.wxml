<view class="countdowns-page">
  <!-- Loading Skeleton -->
  <view class="loading-skeleton" wx:if="{{loading}}">
    <view class="skeleton-header"></view>
    <view class="skeleton-stats"></view>
    <view class="skeleton-search"></view>
    <view class="skeleton-item" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <block wx:else>
    <!-- Header -->
    <view class="countdowns-header">
      <text class="countdowns-title">{{i.title}}</text>
      <view class="header-btns">
        <view class="select-btn {{selectMode ? 'select-btn--active' : ''}}" bind:tap="onToggleSelectMode">
          <text>{{selectMode ? i.cancel : i.select}}</text>
        </view>
        <view class="add-btn" bind:tap="onAddCountdown">
          <text class="add-icon">+</text>
          <text class="add-text">{{i.add}}</text>
        </view>
      </view>
    </view>

    <!-- Stats Row -->
    <view class="stats-row">
      <view class="stat-card glass-card">
        <text class="stat-value stat-value--upcoming">{{upcomingCount}}</text>
        <text class="stat-label">{{i.upcoming}}</text>
      </view>
      <view class="stat-card glass-card">
        <text class="stat-value stat-value--due-soon">{{dueSoonCount}}</text>
        <text class="stat-label">{{i.dueSoon}}</text>
      </view>
      <view class="stat-card glass-card">
        <text class="stat-value stat-value--overdue">{{overdueCount}}</text>
        <text class="stat-label">{{i.overdue}}</text>
      </view>
    </view>

    <!-- Search Bar -->
    <view class="search-box glass-card">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="{{i.searchPlaceholder}}" placeholder-style="color: var(--text-muted)" value="{{searchText}}" bindinput="onSearchInput" />
      <text wx:if="{{searchText}}" class="search-clear" bind:tap="onSearchClear">✕</text>
    </view>

    <!-- Priority Filter -->
    <view class="filter-row">
      <view class="filter-chips">
        <view class="filter-chip {{priorityFilter === '' ? 'filter-chip--active' : ''}}" bind:tap="onPriorityFilter" data-priority="">
          <text>{{i.all}}</text>
        </view>
        <view class="filter-chip {{priorityFilter === 'high' ? 'filter-chip--active' : ''}} filter-chip--high" bind:tap="onPriorityFilter" data-priority="high">
          <text>{{i.high}}</text>
        </view>
        <view class="filter-chip {{priorityFilter === 'medium' ? 'filter-chip--active' : ''}} filter-chip--medium" bind:tap="onPriorityFilter" data-priority="medium">
          <text>{{i.medium}}</text>
        </view>
        <view class="filter-chip {{priorityFilter === 'low' ? 'filter-chip--active' : ''}} filter-chip--low" bind:tap="onPriorityFilter" data-priority="low">
          <text>{{i.low}}</text>
        </view>
      </view>
    </view>

    <!-- Select Mode Actions -->
    <view class="select-actions" wx:if="{{selectMode}}">
      <text class="select-count">{{selectedIds.length}} {{i.selected}}</text>
      <view class="select-btns">
        <text class="select-action-btn" bind:tap="onSelectAll">{{i.all}}</text>
        <text class="select-action-btn" bind:tap="onDeselectAll">{{i.none}}</text>
        <text class="select-action-btn select-action-btn--danger" bind:tap="onBatchDelete">{{i.delete}}</text>
      </view>
    </view>

    <!-- Pinned Section -->
    <view class="section" wx:if="{{pinned.length > 0}}">
      <view class="section-header">
        <text class="section-icon">📌</text>
        <text class="section-title-text">{{i.pinned}}</text>
        <badge text="{{pinned.length}}" variant="info"></badge>
      </view>
      <view class="countdown-list">
        <view wx:for="{{pinned}}" wx:key="id" class="countdown-row">
          <view wx:if="{{selectMode}}" class="countdown-checkbox-wrap" bind:tap="onToggleSelect" data-id="{{item.id}}">
            <view class="countdown-checkbox {{selectedIds.indexOf(item.id) !== -1 ? 'countdown-checkbox--checked' : ''}}">
              <text wx:if="{{selectedIds.indexOf(item.id) !== -1}}" class="countdown-check-icon">✓</text>
            </view>
          </view>
          <view class="countdown-card-wrap">
            <countdown-card countdown="{{item}}"
              bind:edit="onCountdownEdit" bind:delete="onCountdownDelete" bind:pin="onCountdownPin">
            </countdown-card>
          </view>
        </view>
      </view>
    </view>

    <!-- Unpinned Section -->
    <view class="section" wx:if="{{unpinned.length > 0}}">
      <view class="section-header" wx:if="{{pinned.length > 0}}">
        <text class="section-title-text">{{i.countdowns}}</text>
        <badge text="{{unpinned.length}}" variant="info"></badge>
      </view>
      <view class="countdown-list">
        <view wx:for="{{unpinned}}" wx:key="id" class="countdown-row">
          <view wx:if="{{selectMode}}" class="countdown-checkbox-wrap" bind:tap="onToggleSelect" data-id="{{item.id}}">
            <view class="countdown-checkbox {{selectedIds.indexOf(item.id) !== -1 ? 'countdown-checkbox--checked' : ''}}">
              <text wx:if="{{selectedIds.indexOf(item.id) !== -1}}" class="countdown-check-icon">✓</text>
            </view>
          </view>
          <view class="countdown-card-wrap">
            <countdown-card countdown="{{item}}"
              bind:edit="onCountdownEdit" bind:delete="onCountdownDelete" bind:pin="onCountdownPin">
            </countdown-card>
          </view>
        </view>
      </view>
    </view>

    <!-- Empty State -->
    <view class="empty-full" wx:if="{{countdowns.length === 0}}">
      <empty-state
        icon="⏰"
        title="{{i.noCountdowns}}"
        description="{{i.noCountdownsHint}}">
      </empty-state>
    </view>

    <view class="empty-full" wx:if="{{countdowns.length > 0 && pinned.length === 0 && unpinned.length === 0}}">
      <empty-state
        icon="🔍"
        title="{{i.noMatches}}"
        description="{{i.noMatchesHint}}">
      </empty-state>
    </view>

    <!-- Form Modal -->
    <modal show="{{showFormModal}}" title="{{formTitle}}" bind:close="onCloseModal" bind:confirm="onFormSave">
      <view class="form-body">
        <view class="form-group">
          <text class="form-label">{{i.name}}</text>
          <input class="form-input" placeholder="{{i.countdownName}}" placeholder-style="color: var(--text-muted)"
            value="{{form.title}}" bindinput="onFormTitleInput" maxlength="100" />
        </view>

        <view class="form-group">
          <text class="form-label">{{i.targetDate}}</text>
          <view class="date-time-row">
            <picker mode="date" value="{{form.targetDate}}" bindchange="onFormDateChange">
              <view class="form-picker form-picker--half">
                <text class="form-picker-text">{{form.targetDate || i.selectDate}}</text>
                <text class="chip-arrow">▾</text>
              </view>
            </picker>
            <picker mode="time" value="{{form.targetTime}}" bindchange="onFormTimeChange">
              <view class="form-picker form-picker--half">
                <text class="form-picker-text">{{form.targetTime || i.selectTime}}</text>
                <text class="chip-arrow">▾</text>
              </view>
            </picker>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">{{i.priority}}</text>
          <picker mode="selector" range="{{i.priorityLabels}}" value="{{formPriorityIdx}}" bindchange="onFormPriorityChange">
            <view class="form-picker">
              <view class="form-picker-left">
                <view class="priority-dot priority-dot--{{form.priority}}"></view>
                <text class="form-picker-text">{{formPriorityLabel}}</text>
              </view>
              <text class="chip-arrow">▾</text>
            </view>
          </picker>
        </view>
      </view>
    </modal>

    <view class="safe-bottom"></view>
  </block>
</view>
